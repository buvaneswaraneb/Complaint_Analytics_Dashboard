# Supabase shared complaint store
# Copy this file to .env locally, or set the same values in Streamlit Cloud/Vercel.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key

# Optional. Use this on trusted servers only. Never expose it in browser code.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional. Defaults to "complaints".
SUPABASE_TABLE=complaints
